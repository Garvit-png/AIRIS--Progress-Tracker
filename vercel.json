{
  "redirects": [
    {
      "source": "/api/test-redirect",
      "destination": "https://www.google.com",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
